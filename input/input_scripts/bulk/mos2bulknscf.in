&control
    calculation = 'nscf'
    prefix = 'mos2bulk'
    outdir = './mos2bulk/'
    pseudo_dir = './pseudos/'
    verbosity   = 'high'
/

&system
    ibrav=0,
    nat=6, 
    ntyp=2, 
    ecutwfc=40,
    ecutrho = 400,
    nbnd = 80,
    occupations = 'fixed',
    noncolin = .true.,
    lspinorb = .true.

/

&electrons
    conv_thr=1.0d-8,
    mixing_beta = 0.3,
    electron_maxstep = 200,
/

ATOMIC_SPECIES
  Mo  95.95  Mo.UPF
  S   32.06  S.UPF


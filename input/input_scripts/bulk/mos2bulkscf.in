&control
    calculation = 'scf',
    prefix = 'mos2bulk',
    outdir = './mos2bulk/',
    pseudo_dir = './pseudos/',
    etot_conv_thr = 1.0d-5,
    forc_conv_thr = 1.0d-4,
    verbosity   = 'high',
/

&system
    ibrav=0,
    nat=6, 
    ntyp=2, 
    ecutwfc=40,
    ecutrho = 400,
    occupations = 'smearing',
    smearing = 'mv',
    degauss = 0.02,
    noncolin = .true.,
    lspinorb = .true.

/

&electrons
    conv_thr=1.0d-8
    mixing_beta = 0.3,
    electron_maxstep = 200,
/

&ions
    ion_dynamics = 'bfgs'
/

&cell
    cell_dofree='all'
/

ATOMIC_SPECIES
  Mo  95.95  Mo.UPF
  S   32.06  S.UPF

